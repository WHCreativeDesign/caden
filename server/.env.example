# ── Groq API keys ─────────────────────────────────────────────────────────────
# Create accounts at console.groq.com and paste keys comma-separated.
# The server cycles through them automatically when one hits a rate limit.
GROQ_API_KEYS=gsk_key1,gsk_key2,gsk_key3

# ── Gemini API keys ────────────────────────────────────────────────────────────
# Get keys at aistudio.google.com — free tier is generous.
GEMINI_API_KEYS=AIza_key1,AIza_key2

# ── Server ─────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# Comma-separated allowed origins. Use * to allow the local frontend.
# On Pi, set this to your Pi's local IP so only your LAN can call it.
CORS_ORIGINS=*

# ── Communication (Twilio) ────────────────────────────────────────────────────
# Optional — only needed if you use send_text / make_call tools.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+15551234567
