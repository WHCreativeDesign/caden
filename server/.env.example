# ── Supabase key store (recommended) ──────────────────────────────────────────
# Caden pulls its Groq (chat) + Gemini (voice) key pools from the Supabase
# `caden_api_keys` table so you can add an UNLIMITED number of free-tier keys
# without redeploying. Add keys via SQL, the Supabase dashboard, or the backend's
# POST /keys endpoint. The URL below is Caden's actual Supabase project and is
# already the default in config.py — only uncomment it if you're pointing at a
# different project. The service-role key IS secret (never commit a real one)
# and is required to read the locked-down table — grab it from that project's
# Settings → API → service_role (secret), and paste it in below.
# SUPABASE_URL=https://lrjiopczasvcrhglweth.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# SUPABASE_KEYS_TABLE=caden_api_keys       # override the table name if needed
# KEY_REFRESH_INTERVAL=300                  # seconds between pool re-syncs (0 = off)

# ── Groq API keys (optional env seed) ─────────────────────────────────────────
# Create accounts at console.groq.com and paste keys comma-separated. These are
# MERGED with the Supabase pool — leave blank to source keys from Supabase only.
# The server cycles through them automatically when one hits a rate limit.
GROQ_API_KEYS=

# ── Gemini API keys (optional env seed) — powers voice ─────────────────────────
# Get keys at aistudio.google.com — free tier is generous. Also merged with the
# Supabase 'gemini' pool.
GEMINI_API_KEYS=

# Model the voice layer targets (draws from the cycled Gemini key pool).
# GEMINI_VOICE_MODEL=gemini-2.0-flash

# ── Server ─────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# Comma-separated allowed origins. Use * to allow the local frontend.
# On Pi, set this to your Pi's local IP so only your LAN can call it.
CORS_ORIGINS=*

# ── Communication (Twilio) ────────────────────────────────────────────────────
# Optional — only needed if you use send_text / make_call tools.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+15551234567
