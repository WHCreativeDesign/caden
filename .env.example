# Copy to .env for local dev, or point systemd/caden.service's
# EnvironmentFile= at a copy of this on the Pi (e.g. /home/pi/caden/.env).

# Comma-separated free-tier keys, no spaces around the commas — add as many
# as you have, they're cycled round-robin with automatic 429 backoff.
# Groq is primary, Gemini is the fallback.
#   GROQ_API_KEYS=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx,gsk_yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy
#   GEMINI_API_KEYS=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx,AIzaSyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy
GROQ_API_KEYS=
GEMINI_API_KEYS=

# Web UI port.
PORT=7777

# "auto" (default) | "local" | "stream" — see src/tools/browser.ts.
BROWSER_MODE=auto

# Self-update: branch to track and how often to check, in ms.
UPDATE_BRANCH=main
UPDATE_INTERVAL_MS=180000

# Optional: force status SFX to a specific ALSA device if the system default
# doesn't route to the output you want (e.g. HDMI is default even with
# headphones plugged into the 3.5mm jack). Find yours with `aplay -l`, then
# use "plughw:<card>,<device>", e.g.:
#   SFX_AUDIO_DEVICE=plughw:0,0
# See CLAUDE.md's SFX troubleshooting section if there's no sound at all.
SFX_AUDIO_DEVICE=

# Optional: Telegram bot, so Caden is reachable from outside the house —
# text and voice notes, reusing the same agent loop as the web UI. These two
# are only the FIRST-BOOT default — once anything is saved from the web UI's
# Options tab (Telegram section), that takes over and these are ignored, so
# there's no need to edit this file again to change the bot token or the
# allowed chat ids later. Create a bot with @BotFather to get a token.
# TELEGRAM_ALLOWED_CHAT_IDS is REQUIRED for the bot to answer anyone — this
# bot has the same full shell/browser access as the web UI, so an
# unauthenticated bot would hand that to whoever finds it. Message your bot
# once, then check
#   https://api.telegram.org/bot<token>/getUpdates
# for your chat id (message.chat.id) and add it here (or in the Options
# tab). Comma-separated for more than one person/device.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=

# Optional: OpenWeatherMap key for get_weather — same "first-boot default,
# Options tab takes over once set there" pattern as the Telegram vars above.
# Without a key, get_weather still works via wttr.in (no key needed); with
# one, OpenWeatherMap is tried first (falls back to wttr.in if it ever
# fails). Get a free key at https://openweathermap.org/api.
OPENWEATHER_API_KEY=

# Optional: override the Pi's local SFX playback compensation (ms). Normally
# this is measured automatically per-Pi (see src/sfx.ts) to keep the Pi's
# speaker in sync with the browser rather than trailing behind it — only set
# this if auto-calibration seems wrong for your hardware. Check GET
# /api/status's "sfx" field (or the Options tab) to see the current
# calibrated value before overriding it.
SFX_LOCAL_LATENCY_MS=
