# Copy to .env for local dev, or point systemd/caden.service's
# EnvironmentFile= at a copy of this on the Pi (e.g. /home/pi/caden/.env).

# Comma-separated free-tier keys, no spaces around the commas — add as many
# as you have, they're cycled round-robin with automatic 429 backoff.
# Groq is primary, Gemini is the fallback.
#   GROQ_API_KEYS=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx,gsk_yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy
#   GEMINI_API_KEYS=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx,AIzaSyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy
GROQ_API_KEYS=
GEMINI_API_KEYS=

# Web UI port.
PORT=7777

# "auto" (default) | "local" | "stream" — see src/tools/browser.ts.
BROWSER_MODE=auto

# Self-update: branch to track and how often to check, in ms.
UPDATE_BRANCH=main
UPDATE_INTERVAL_MS=180000
